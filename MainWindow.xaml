<Window x:Class="Crisol.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crisol" Height="640" Width="520" MinWidth="460" MinHeight="480"
        Background="#FF1E1E24" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFEAEAEA"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFEAEAEA"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
        </Style>
        <DataTemplate x:Key="DeviceRowTemplate">
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="34"/>
                </Grid.ColumnDefinitions>
                <CheckBox Content="{Binding Label}" IsChecked="{Binding Enabled, Mode=TwoWay}"
                          IsEnabled="{Binding IsUnlocked}" ToolTip="{Binding LockReason}"
                          ToolTipService.ShowOnDisabled="True"
                          Checked="Row_Toggled" Unchecked="Row_Toggled"
                          VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Maximum="100" Value="{Binding Volume, Mode=TwoWay}"
                        IsEnabled="{Binding IsUnlocked}"
                        ValueChanged="RowVolume_Changed" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding VolumeText}" TextAlignment="Right"
                           VerticalAlignment="Center" Foreground="#FF9A9AA5"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Margin="14">
        <!-- Pie: volumen general, autoinicio y estado -->
        <StackPanel DockPanel.Dock="Bottom">
            <Separator Margin="0,10,0,8" Background="#FF3A3A44"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Volumen general" VerticalAlignment="Center"/>
                <Slider x:Name="MasterSlider" Grid.Column="1" Maximum="100" Value="100"
                        VerticalAlignment="Center" ValueChanged="Master_Changed"/>
                <TextBlock x:Name="MasterPct" Grid.Column="2" Text="100" TextAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <CheckBox x:Name="AutostartCheck" Margin="0,10,0,0"
                      Content="Iniciar con Windows (arranca en la bandeja)"
                      Checked="Autostart_Changed" Unchecked="Autostart_Changed"/>
            <TextBlock x:Name="StatusText" Margin="0,8,0,0" Foreground="#FF9A9AA5" TextWrapping="Wrap" FontSize="11"/>
        </StackPanel>

        <!-- Cabecera con refrescar -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
            <Button DockPanel.Dock="Right" Content="⟳" Width="30" Height="24"
                    ToolTip="Actualizar dispositivos" Click="Refresh_Click"/>
            <TextBlock Text="Marca qué entra a la mezcla y por dónde sale. Todo suena a la vez, sincronizado."
                       FontSize="11" Foreground="#FF9A9AA5" TextWrapping="Wrap" VerticalAlignment="Center"/>
        </DockPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="FUENTES (lo que entra)" FontWeight="SemiBold" FontSize="11"
                           Foreground="#FFE8853B" Margin="0,6,0,2"/>
                <TextBlock Text="Lo que suena en un dispositivo (loopback) o un micrófono, cada uno con su volumen."
                           FontSize="11" Foreground="#FF9A9AA5" Margin="0,0,0,6" TextWrapping="Wrap"/>
                <ItemsControl x:Name="SourcesList" ItemTemplate="{StaticResource DeviceRowTemplate}"/>

                <Separator Margin="0,10,0,6" Background="#FF3A3A44"/>

                <TextBlock Text="SALIDAS (por dónde suena)" FontWeight="SemiBold" FontSize="11"
                           Foreground="#FFE8853B" Margin="0,0,0,2"/>
                <TextBlock Text="La misma mezcla se reproduce en todas las salidas marcadas, cada una con su volumen."
                           FontSize="11" Foreground="#FF9A9AA5" Margin="0,0,0,6" TextWrapping="Wrap"/>
                <ItemsControl x:Name="OutputsList" ItemTemplate="{StaticResource DeviceRowTemplate}"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
